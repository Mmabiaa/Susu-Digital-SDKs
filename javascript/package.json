{
    "name": "@susudigital/sdk",
    "version": "2.1.0",
    "description": "Enterprise-Grade JavaScript/TypeScript SDK for Susu Digital's microfinance platform",
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.js",
    "types": "./dist/types/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/esm/index.js",
            "require": "./dist/cjs/index.js",
            "types": "./dist/types/index.d.ts"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "node node_modules/typescript/bin/tsc -p tsconfig.cjs.json && node node_modules/typescript/bin/tsc -p tsconfig.esm.json && node node_modules/typescript/bin/tsc -p tsconfig.types.json",
        "build:watch": "node node_modules/typescript/bin/tsc -p tsconfig.esm.json --watch",
        "test": "node node_modules/jest-cli/bin/jest.js",
        "test:watch": "node node_modules/jest-cli/bin/jest.js --watch",
        "test:coverage": "node node_modules/jest-cli/bin/jest.js --coverage",
        "lint": "node node_modules/eslint/bin/eslint.js src --ext .ts",
        "lint:fix": "node node_modules/eslint/bin/eslint.js src --ext .ts --fix",
        "format": "node node_modules/prettier/bin/prettier.cjs --write \"src/**/*.ts\" \"tests/**/*.ts\"",
        "typecheck": "node node_modules/typescript/bin/tsc --noEmit",
        "prepublishOnly": "npm run build && npm test"
    },
    "keywords": [
        "susudigital",
        "microfinance",
        "fintech",
        "ghana",
        "sdk",
        "api",
        "typescript"
    ],
    "author": "Susu Digital <sdk-support@susudigital.app>",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Mmabiaa/Susu-Digital-SDKs.git"
    },
    "homepage": "https://developers.susudigital.app/js-sdk",
    "bugs": {
        "url": "https://github.com/Mmabiaa/Susu-Digital-SDKs/issues"
    },
    "engines": {
        "node": ">=16.0.0"
    },
    "dependencies": {
        "node-fetch": "^3.3.2"
    },
    "devDependencies": {
        "@types/jest": "^29.5.0",
        "@types/node": "^20.0.0",
        "@typescript-eslint/eslint-plugin": "^6.0.0",
        "@typescript-eslint/parser": "^6.0.0",
        "eslint": "^8.40.0",
        "jest": "^29.5.0",
        "jest-fetch-mock": "^3.0.3",
        "prettier": "^3.0.0",
        "ts-jest": "^29.1.0",
        "typescript": "^5.1.0"
    },
    "jest": {
        "preset": "ts-jest",
        "testEnvironment": "node",
        "setupFilesAfterEnv": [
            "<rootDir>/tests/setup.ts"
        ],
        "testMatch": [
            "**/tests/**/*.test.ts"
        ],
        "moduleNameMapper": {
            "^(.*)\\.js$": "$1"
        },
        "collectCoverageFrom": [
            "src/**/*.ts",
            "!src/**/*.d.ts"
        ],
        "coverageThreshold": {
            "global": {
                "branches": 75,
                "functions": 85,
                "lines": 85,
                "statements": 85
            }
        },
        "globals": {
            "ts-jest": {
                "tsconfig": "tsconfig.test.json"
            }
        }
    }
}
