{
    "name": "susudigital/susudigital-php",
    "description": "Enterprise-Grade PHP SDK for Susu Digital's microfinance platform",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "susudigital",
        "microfinance",
        "fintech",
        "ghana",
        "sdk",
        "api"
    ],
    "authors": [
        {
            "name": "Susu Digital",
            "email": "sdk-support@susudigital.app"
        }
    ],
    "homepage": "https://developers.susudigital.app/php-sdk",
    "support": {
        "issues": "https://github.com/mmabiaa/Susu-digital-sdks/issues",
        "source": "https://github.com/mmabiaa/Susu-digital-sdks"
    },
    "require": {
        "php": "^8.0",
        "ext-json": "*",
        "ext-curl": "*",
        "guzzlehttp/guzzle": "^7.5",
        "guzzlehttp/promises": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "mockery/mockery": "^1.6",
        "pestphp/pest": "^2.0",
        "phpstan/phpstan": "^1.10",
        "friendsofphp/php-cs-fixer": "^3.22"
    },
    "autoload": {
        "psr-4": {
            "SusuDigital\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SusuDigital\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test:coverage": "vendor/bin/phpunit --coverage-html coverage",
        "stan": "vendor/bin/phpstan analyse src --level=8",
        "cs:fix": "vendor/bin/php-cs-fixer fix src tests"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}